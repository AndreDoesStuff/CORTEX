# CORTEX / THALAMUS — Phase 0 credentials
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit tokens.
# The source registry (sources.json) references these by name (e.g. "env:JIRA_API_TOKEN").

# --- Jira (AXON board) — READ-ONLY awareness, never write, ever ---
# Atlassian account email + API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Figma — personal access token: https://www.figma.com/developers/api#access-tokens ---
# Scope needed: file read (file_content:read / file_versions:read).
FIGMA_TOKEN=

# --- GitHub (disabled this pass — fill + enable in sources.json when repos are known) ---
# Fine-grained or classic PAT with `repo` read scope.
GITHUB_TOKEN=

# --- Anthropic API (BROCA narrator layer, Phase 2) ---
# Used only to phrase spoken answers naturally (claude-haiku-4-5); fact packets
# — ticket titles, dates — are sent to Anthropic's API for this step. If unset
# or offline, BROCA falls back to deterministic templates (no dead air).
ANTHROPIC_API_KEY=

# --- Voicebox (BROCA voice-out, Phase 2 v0.2.0) — local, on-device voice cloning ---
# The exact profile name cloned in the Voicebox app. If unset or Voicebox isn't
# reachable, BROCA falls back to macOS `say -v Samantha` automatically.
VOICEBOX_PROFILE_NAME=
# Optional: override the local Voicebox server URL (default http://127.0.0.1:17493).
# VOICEBOX_URL=http://127.0.0.1:17493
